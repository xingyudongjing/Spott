{
  "name": "@spott/api-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": { ".": "./dist/index.js", "./schema": "./dist/schema.d.ts" },
  "scripts": {
    "generate": "openapi-typescript ../contracts/openapi.yaml -o src/schema.d.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ignore-pattern src/schema.d.ts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
