{
  "name": "@spott/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm run build && concurrently -k -n compiler,server -c cyan,magenta \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "start": "node dist/main.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "tsx ../../scripts/test-postgis.ts src/modules/events/events.discovery.integration.spec.ts src/modules/registrations/registrations.concurrency.integration.spec.ts"
  },
  "dependencies": {
    "@apple/app-store-server-library": "3.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@nestjs/common": "^11.1.5",
    "@nestjs/core": "^11.1.5",
    "@nestjs/platform-fastify": "^11.1.5",
    "@spott/domain": "workspace:*",
    "fastify": "^5.4.0",
    "jose": "^6.0.12",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.4",
    "concurrently": "9.2.1",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
