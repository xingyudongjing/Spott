NODE_ENV=development
PORT=4100
DATABASE_URL=postgres://spott:spott@127.0.0.1:55432/spott
REDIS_URL=redis://127.0.0.1:6379
# Comma-separated allowlists are supported. Local development also admits
# localhost/127.0.0.1 ports 3000-3003.
WEB_ORIGIN=http://localhost:3000,http://localhost:3003
OPS_ORIGIN=http://localhost:3001
PUBLIC_API_URL=http://localhost:4100/v1
FIELD_ENCRYPTION_KEY_BASE64=
LOOKUP_HMAC_PEPPER=replace-with-a-secret-pepper
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
# Development/test-only example keyrings. NODE_ENV must be explicit. Keep
# referenced previous KIDs until every signed request/recovery window that uses
# them has expired. Production rejects these decoded example fingerprints even
# under renamed KIDs and requires independently generated secrets.
SPOTT_WEB_BFF_KEYS=bff-2026-07:MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY
SPOTT_WEB_BFF_CURRENT_KID=bff-2026-07
REFRESH_TOKEN_DERIVATION_KEYS=refresh-2026-07:ZmVkY2JhOTg3NjU0MzIxMGZlZGNiYTk4NzY1NDMyMTA
REFRESH_TOKEN_DERIVATION_CURRENT_KID=refresh-2026-07
WEB_SESSION_BFF_ENFORCEMENT=off
WEB_SESSION_RECOVERY_SECONDS=120
WEB_SESSION_COMPLETION_RECOVERY_SECONDS=120
SPOTT_WEB_CANONICAL_ORIGIN=https://spott.jp
# Product website download state. Keep this unavailable until the real App Store
# URL and numeric Apple app ID are both known and verified.
NEXT_PUBLIC_APP_STORE_STATE=unavailable
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_APP_STORE_ID=
# Local-debugging authentication backdoor. When set to `true` AND NODE_ENV is not
# `production`, the API trusts `x-spott-user-id` / `x-spott-role: operator` /
# `x-spott-phone-verified` request headers instead of a real session, letting you curl
# consumer and Ops routes without signing in. It is disabled by default and is forced
# off in production regardless of this value — never set it on a shared or public host.
ENABLE_DEV_HEADER_AUTH=false
OTP_PROVIDER=console
APPLE_BUNDLE_ID=com.yaokai.Spott
APPLE_SERVICE_ID=
APPLE_APP_ID=
APPLE_STORE_ENVIRONMENT=Sandbox
APPLE_ROOT_CA_PATHS=services/api/certs/AppleRootCA-G2.cer,services/api/certs/AppleRootCA-G3.cer
APPLE_ENABLE_ONLINE_CHECKS=true
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# OAuth 2.0 Web application client ID used as the Google ID-token `aud`.
# Do not put the iOS client ID here.
GOOGLE_SERVER_CLIENT_ID=

# Worker media and outbound delivery. These defaults match infrastructure/docker/compose.yaml.
WORKER_ID=spott-local-worker
WORKER_POLL_MS=1000
WORKER_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=12
OBJECT_STORE_PROVIDER=s3
S3_ENDPOINT=http://127.0.0.1:9100
S3_REGION=ap-northeast-1
S3_BUCKET=spott-media
S3_ACCESS_KEY_ID=spott-local
S3_SECRET_ACCESS_KEY=spott-local-secret
S3_FORCE_PATH_STYLE=true
MEDIA_UPLOAD_ORIGIN=http://127.0.0.1:9100/spott-media
MEDIA_PUBLIC_ORIGIN=http://127.0.0.1:9100/spott-media
MEDIA_SCAN_PROVIDER=clamav
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
EMAIL_PROVIDER=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Spott <notifications@spott.local>
PUSH_PROVIDER=console
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.yaokai.Spott
APNS_PRIVATE_KEY=
