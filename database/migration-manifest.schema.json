{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spott.invalid/schemas/migration-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "migrations"],
  "properties": {
    "$schema": {
      "const": "./migration-manifest.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "migrations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "filename", "sha256"],
        "properties": {
          "sequence": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9999
          },
          "filename": {
            "type": "string",
            "pattern": "^[0-9]{4}_[a-z0-9]+(?:_[a-z0-9]+)*\\.sql$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
